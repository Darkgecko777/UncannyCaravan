[gd_scene load_steps=2 format=3 uid="uid://main_scene"]

[ext_resource type="Script" path="res://scenes/main/main.gd" id="1_main"]

[node name="Main" type="Node"]
script = ExtResource("1_main")

[node name="UI" type="CanvasLayer" parent="."]

[node name="Margin" type="MarginContainer" parent="UI"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="UI/Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Header" type="HBoxContainer" parent="UI/Margin/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="UI/Margin/VBox/Header"]
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "UNCANNY CARAVAN — Phase 0 Skeleton"

[node name="Spacer" type="Control" parent="UI/Margin/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3

[node name="CashLabel" type="Label" parent="UI/Margin/VBox/Header"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Ceramic Bits: 850"

[node name="Body" type="HBoxContainer" parent="UI/Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 16

[node name="LeftPanel" type="VBoxContainer" parent="UI/Margin/VBox/Body"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="InventoryBox" type="PanelContainer" parent="UI/Margin/VBox/Body/LeftPanel"]
layout_mode = 2
size_flags_vertical = 3

[node name="Margin" type="MarginContainer" parent="UI/Margin/VBox/Body/LeftPanel/InventoryBox"]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 6
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 6

[node name="InventoryLabel" type="RichTextLabel" parent="UI/Margin/VBox/Body/LeftPanel/InventoryBox/Margin"]
unique_name_in_owner = true
layout_mode = 2
bbcode_enabled = true
fit_content = true
text = "[b]Inventory[/b]"

[node name="CaravansBox" type="PanelContainer" parent="UI/Margin/VBox/Body/LeftPanel"]
layout_mode = 2
size_flags_vertical = 3

[node name="Margin" type="MarginContainer" parent="UI/Margin/VBox/Body/LeftPanel/CaravansBox"]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 6
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 6

[node name="VBox" type="VBoxContainer" parent="UI/Margin/VBox/Body/LeftPanel/CaravansBox/Margin"]
layout_mode = 2

[node name="Label" type="Label" parent="UI/Margin/VBox/Body/LeftPanel/CaravansBox/Margin/VBox"]
layout_mode = 2
text = "Active Caravans (stub)"

[node name="CaravanList" type="VBoxContainer" parent="UI/Margin/VBox/Body/LeftPanel/CaravansBox/Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2

[node name="RightPanel" type="VBoxContainer" parent="UI/Margin/VBox/Body"]
layout_mode = 2
size_flags_horizontal = 3

[node name="DebugBox" type="PanelContainer" parent="UI/Margin/VBox/Body/RightPanel"]
layout_mode = 2
size_flags_vertical = 3

[node name="Margin" type="MarginContainer" parent="UI/Margin/VBox/Body/RightPanel/DebugBox"]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 6
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 6

[node name="VBox" type="VBoxContainer" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin"]
layout_mode = 2

[node name="DebugTitle" type="Label" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox"]
layout_mode = 2
text = "DEBUG CONTROLS (Phase 0)"
horizontal_alignment = 1

[node name="Buttons" type="GridContainer" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox"]
layout_mode = 2
columns = 2
theme_override_constants/h_separation = 6
theme_override_constants/v_separation = 6

[node name="GiveCashBtn" type="Button" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons"]
layout_mode = 2
text = "+500 Bits"

[node name="GiveGoodsBtn" type="Button" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons"]
layout_mode = 2
text = "Add Test Goods"

[node name="MarketTickBtn" type="Button" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons"]
layout_mode = 2
text = "Force Market Tick"

[node name="SendCaravanBtn" type="Button" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons"]
layout_mode = 2
text = "Send Test Caravan (stub)"

[node name="SaveBtn" type="Button" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons"]
layout_mode = 2
text = "Force Save"

[node name="OfflineBtn" type="Button" parent="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons"]
layout_mode = 2
text = "Simulate 4h Offline"

[node name="LogBox" type="PanelContainer" parent="UI/Margin/VBox/Body/RightPanel"]
layout_mode = 2
size_flags_vertical = 3

[node name="Margin" type="MarginContainer" parent="UI/Margin/VBox/Body/RightPanel/LogBox"]
layout_mode = 2
theme_override_constants/margin_left = 6
theme_override_constants/margin_top = 4
theme_override_constants/margin_right = 6
theme_override_constants/margin_bottom = 4

[node name="DebugLog" type="RichTextLabel" parent="UI/Margin/VBox/Body/RightPanel/LogBox/Margin"]
unique_name_in_owner = true
layout_mode = 2
bbcode_enabled = true
scroll_following = true
text = "[color=#888888]Event log...[/color]\n"

[node name="Footer" type="HBoxContainer" parent="UI/Margin/VBox"]
layout_mode = 2

[node name="FooterLabel" type="Label" parent="UI/Margin/VBox/Footer"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
modulate = Color(0.6, 0.6, 0.6, 1)
text = "Uncanny Caravan — Godot 4.6 MVP • Clarity • Immersion • Agency • Save works • Close window to auto-save"

[connection signal="pressed" from="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons/GiveCashBtn" to="." method="_on_give_cash_pressed"]
[connection signal="pressed" from="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons/GiveGoodsBtn" to="." method="_on_give_goods_pressed"]
[connection signal="pressed" from="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons/MarketTickBtn" to="." method="_on_market_tick_pressed"]
[connection signal="pressed" from="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons/SendCaravanBtn" to="." method="_on_send_test_caravan_pressed"]
[connection signal="pressed" from="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons/SaveBtn" to="." method="_on_save_pressed"]
[connection signal="pressed" from="UI/Margin/VBox/Body/RightPanel/DebugBox/Margin/VBox/Buttons/OfflineBtn" to="." method="_on_force_offline_pressed"]
